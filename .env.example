# LLM Council Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: OpenRouter API
# =============================================================================
# Get your API key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon key for JWKS endpoint access (same as VITE_SUPABASE_ANON_KEY)
# Required for ES256 JWT verification
SUPABASE_ANON_KEY=your-anon-key-here

# JWT secret for verifying auth tokens (Settings > API > JWT Settings)
# Note: Only used for HS256 tokens; ES256 uses JWKS instead
SUPABASE_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# OPTIONAL: Legacy Authentication (DEPRECATED)
# =============================================================================
# Legacy password auth - will be removed in future versions
# Use Supabase Auth instead
# COUNCIL_API_PASSWORD=change-this-to-a-secure-password

# =============================================================================
# OPTIONAL: CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
# For local development, defaults to localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# =============================================================================
# REQUIRED: Frontend Supabase (for auth)
# =============================================================================
# Get these from your Supabase project: Settings > API
# Note: Use the anon/public key, NOT the service role key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# OPTIONAL: Frontend API URL
# =============================================================================
# Only needed if frontend is on a different domain than API
# Leave empty for same-origin deployment (recommended)
VITE_API_URL=
