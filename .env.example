# LLM Council Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: OpenRouter API
# =============================================================================
# Get your API key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# =============================================================================
# REQUIRED: Supabase Database
# =============================================================================
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# REQUIRED FOR PRODUCTION: Authentication
# =============================================================================
# Set a strong password for API access
COUNCIL_API_PASSWORD=change-this-to-a-secure-password

# =============================================================================
# OPTIONAL: CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
# For local development, defaults to localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# =============================================================================
# OPTIONAL: Frontend API URL
# =============================================================================
# Only needed if frontend is on a different domain than API
# Leave empty for same-origin deployment (recommended)
VITE_API_URL=
